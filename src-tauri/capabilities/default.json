{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "process:allow-restart",
    "os:allow-all"
  ]
}
