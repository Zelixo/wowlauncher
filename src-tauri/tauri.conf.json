{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ikhan Launcher",
  "version": "0.1.0",
  "identifier": "net.zelixo.wowlauncher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build-frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Ikhan Launcher",
        "width": 700,
        "height": 850,
        "resizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/aria2c"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
